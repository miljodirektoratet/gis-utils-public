// Local VS Code Extension Configurations
// Not used by Devcontainer instead configs are listed in .devcontainer/devcontainer.json
{
  // Terminal
  "terminal.integrated.defaultProfile.windows": "Command Prompt",
  "terminal.integrated.defaultProfile.linux": "Bash",

  // Profiles, Editors, and Themes
  "editor.rulers": [
    { "column": 88, "color": "#737171" },
  ],
  "editor.tabSize": 2,
  "workbench.colorCustomizations": {
    "activityBar.background": "#181818",
    "titleBar.activeBackground": "#181818",
    "titleBar.activeForeground": "#cccccc"
  },  

  // Python formatting
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
  },
  "ruff.interpreter": [
    ".venv/Scripts/python",
    ".venv/bin/python",
  ],
  "autoDocstring.docstringFormat": "one-line-sphinx",
  "python.useEnvironmentsExtension": true, // Use Python Envy instead

  // YAML formatting
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "[yml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },

  // TOML formatting
  "[toml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "evenBetterToml.formatter.allowedBlankLines": 2,

  // Markdown formatting
  "[markdown]":{
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },

  // Markdown Table of Contents settings
  "markdown.extension.toc.levels": "2..2",
  "markdown.extension.toc.updateOnSave": true,

  // Git
  "git.branchProtection": ["main"],
  "git.allowNoVerifyCommit": true,
  "git.confirmNoVerifyCommit": false,
  
  // Docker
  "containers.contexts.showInStatusBar": true,
  "python-envs.pythonProjects": [
    {
      "path": ".",
      "envManager": "ms-python.python:conda",
      "packageManager": "ms-python.python:conda"
    }
  ],
  
}
