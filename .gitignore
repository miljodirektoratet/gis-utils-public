# Basic Python .gitignore
# Tip: for a more comprehensive .gitignore see GitHubs Python.gitignore
# > https://github.com/github/gitignore/blob/main/Python.gitignore

# Python-generated files
__pycache__/
*.py[oc]
*.py[cod]
*.pyo
*.pyd

# Packaging
build/
dist/
wheels/
*.egg-info
_version.py

# Virtual environments
.venv
venv/
.pixi/
env/

# Ruff stuff:
.ruff_cache/

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# pytest: unit test / coverage reports
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# Notebooks
.ipynb_checkpoints/

# VS Code
.vscode/*.code-workspace
/.env
notebooks/.env

# Folders
braindump/
tmp/
